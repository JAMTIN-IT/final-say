# ─── Firebase Client SDK ──────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs (one per plan)
STRIPE_PRICE_ESSENTIAL=price_...
STRIPE_PRICE_LEGACY=price_...
STRIPE_PRICE_FAMILY=price_...

# ─── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── Encryption ───────────────────────────────────────────────────────────────
# A random 32-character secret used as the encryption pepper.
# Generate with: openssl rand -base64 32
ENCRYPTION_PEPPER=your_32_char_random_secret

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com
